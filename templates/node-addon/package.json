{
  "name": "__PACKAGE_NAME__",
  "version": "0.1.0",
  "description": "A Node.js native addon built with zig-napi.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node",
    "*.wasm",
    "*.wasi.cjs",
    "*.wasi-browser.js",
    "wasi-worker.mjs",
    "wasi-worker-browser.mjs"
  ],
  "scripts": {
    "build": "zig-napi build",
    "build:release": "zig-napi build --release",
    "create-npm-dirs": "zig-napi create-npm-dirs",
    "artifacts": "zig-napi artifacts --output-dir zig-out/node",
    "pre-publish": "zig-napi pre-publish --no-gh-release --skip-optional-publish",
    "package": "zig-napi package",
    "test": "node test.js"
  },
  "devDependencies": {
    "zig-napi": "file:__ZIG_NAPI_PATH__"
  },
  "napi": {
    "binaryName": "__ADDON_NAME__",
    "packageName": "__PACKAGE_NAME__",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "wasm32-wasip1-threads"
    ]
  },
  "license": "MIT"
}
