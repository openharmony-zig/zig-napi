.{
    .name = .__ZIG_PACKAGE_NAME__,
    .version = "0.1.0",
    .minimum_zig_version = "0.16.0",
    .fingerprint = __FINGERPRINT__,
    .dependencies = .{
        .@"zig-napi" = .{
            .path = "__ZIG_NAPI_PATH__",
        },
    },
    .paths = .{
        "build.zig",
        "build.zig.zon",
        "src",
        "index.js",
        "test.js",
        "package.json",
    },
}
