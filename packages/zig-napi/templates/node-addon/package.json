{
  "name": "__PACKAGE_NAME__",
  "version": "0.1.0",
  "description": "A Node.js native addon built with zig-napi.",
  "keywords": [
    "N-API",
    "NAPI",
    "Zig",
    "node-addon",
    "node-addon-api",
    "zig-napi"
  ],
  "license": "MIT",
  "files": [
    "index.js",
    "index.d.ts",
    "browser.js",
    "*.node",
    "*.wasm",
    "*.wasi.cjs",
    "*.wasi-browser.js",
    "wasi-worker.mjs",
    "wasi-worker-browser.mjs"
  ],
  "main": "index.js",
  "browser": "browser.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "artifacts": "zig-napi artifacts",
    "build": "zig-napi build --release",
    "build:debug": "zig-napi build",
    "prepublishOnly": "zig-napi pre-publish --no-gh-release",
    "test": "npm run build:test && npm run test:run",
    "build:test": "npm run build",
    "test:run": "ava"
  },
  "dependencies": {
    "@emnapi/core": "^1.11.0",
    "@emnapi/runtime": "^1.11.0",
    "@napi-rs/wasm-runtime": "^1.1.6",
    "emnapi": "^1.11.1"
  },
  "devDependencies": {
    "ava": "^8.0.0",
    "zig-napi": "^0.1.0"
  },
  "napi": {
    "binaryName": "__ADDON_NAME__",
    "targets": [
      "__NAPI_TARGETS__"
    ]
  },
  "engines": {
    "node": ">=20.17"
  }
}
